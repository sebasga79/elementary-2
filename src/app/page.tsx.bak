    level: "B1 - Intermediate 4",
    objectives: [
      "Propose and evaluate solutions to real and hypothetical problems",
      "Use zero conditional for facts and general truths",
      "Use first conditional for real future possibilities",
      "Use second conditional for imaginary situations",
      "Use third conditional for unreal past situations (regrets)"
    ],
    keyLanguage: [
      { expression: "Zero: If + present, present", example: "If you heat ice, it melts.", use: "Facts, general truths" },
      { expression: "First: If + present, will + verb", example: "If it rains, I'll stay home.", use: "Real future possibilities" },
      { expression: "Second: If + past, would + verb", example: "If I were rich, I'd travel.", use: "Imaginary situations" },
      { expression: "Third: If + had + V3, would have + V3", example: "If I had studied, I would have passed.", use: "Unreal past, regrets" }
