    subtitle: "Mixed Conditionals & Proposals",
    color: "from-amber-500 to-orange-600",
    lightColor: "bg-amber-50",
    borderColor: "border-amber-200",
    icon: icons.message,
    duration: "Multiple Classes",
    level: "B1 - Intermediate 4",
    objectives: [
      "Discuss hypothetical outcomes of past or present decisions",
      "Use mixed conditionals (past → present, present → past)",
      "Make proposals using gerunds and infinitives correctly",
      "Negotiate group decisions respecting others' perspectives"
    ],
    keyLanguage: [
      { expression: "Mixed (Past → Present):", example: "If I had studied medicine, I would be a doctor now.", use: "Past condition, present result" },
