const decisionPitchTemplate = [
  {
    title: 'What decision are you thinking about?',
    example: "I'm thinking about studying abroad.",
    lines: 3,
  },
  {
    title: 'What options are you considering?',
    example: "I'm considering studying in Canada or Spain.",
    lines: 3,
  },
  {
    title: 'What do you prefer to do - and why?',
    example: 'I prefer to study in Spain because I love the culture.',
    lines: 3,
  },
  {
    title: 'What would you rather avoid?',
    example: "I'd rather avoid studying online because I want to meet people in person.",
    lines: 3,
  },
  {
    title: 'What do you plan to or intend to do next?',
    example: 'I plan to apply for a scholarship next month.',
    lines: 3,
  },
  {
    title: 'What are you looking forward to after making your decision?',
    example: 'I look forward to starting a new chapter in my life!',
    lines: 3,
  },
  {
    title: 'My 1-Minute Decision Pitch (Practice Notes)',
    example: 'Try to include at least three target expressions.',
    lines: 6,
  },
] as const

const decisionPitchSelfCheck = [
  'prefer to',
  'would rather',
  'consider doing',
  'plan to / intend to',
  'look forward to',
] as const

