// Types
interface Activity {
  title: string
  time: string
  materials?: string
  instructions?: string
  studentTask: string
  example?: string
  teacherNote: string
  icon?: string
}

interface WarmUp {
  title: string
  time: string
  materials: string
  instructions: string
  teacherNote: string
  audioSrc?: string
}

interface ExpandedActivity {
  section: string
  activity: WarmUp | Activity
}

const isRegularActivity = (activity: WarmUp | Activity): activity is Activity => 'studentTask' in activity

